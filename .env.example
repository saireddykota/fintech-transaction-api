# Application
NODE_ENV=development
PORT=3000

# MongoDB — financial transaction database
MONGODB_URI=mongodb://localhost:27017/fintech_transactions

# Redis — high-frequency caching for financial data lookups
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Kafka — event streaming for async transaction processing
KAFKA_BROKERS=localhost:9092
KAFKA_SSL_ENABLED=false
KAFKA_SASL_ENABLED=false
KAFKA_USERNAME=
KAFKA_PASSWORD=

# JWT Authentication
JWT_SECRET=your-256-bit-secret-here
JWT_EXPIRES_IN=1h

# CORS
ALLOWED_ORIGINS=http://localhost:4200,http://localhost:3001

# Rate Limiting (requests per minute)
THROTTLE_TTL=60000
THROTTLE_LIMIT=200
